  "Auth": {
    "AllowedEmailDomains": [
      "umg.edu.gt",
      "alumnos.umg.edu.gt",
      "universidad.edu",
      "alumnos.universidad.edu"
    ]
  },
  "Email": {
    "Host": "smtp.example.com",
    "Port": 587,
    "User": "",
    "Pass": "",
    "UseSsl": true,
    "UseMock": true,
    "From": "noreply@umg.edu.gt"
  },
  "Academic": {
    "DefaultCourseCapacity": 40,
