# Backend environment variables
ConnectionStrings__Default=Host=localhost;Port=5432;Database=academic_db;Username=postgres;Password=postgres
Jwt__Key=ReplaceWithAtLeast32CharsSecret
Jwt__Issuer=Academic.Api
Jwt__Audience=Academic.Client
Jwt__ExpirationMinutes=120
Auth__AllowedEmailDomains__0=universidad.edu
Auth__AllowedEmailDomains__1=alumnos.universidad.edu
Email__Host=smtp.example.com
Email__Port=587
Email__User=
Email__Pass=
Email__UseSsl=true
Email__UseMock=true
Email__From=noreply@universidad.edu
Academic__DefaultCourseCapacity=40
Academic__CertificatesStoragePath=storage/certificates

# Frontend environment variables (example)
NG_APP_API_BASE_URL=http://localhost:5000
